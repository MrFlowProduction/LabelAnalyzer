<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hu.mrflow.labelanalyzer.view.ProjectDetailController"
            styleClass="detail-panel">

    <!-- ── Projekt neve (fejléc) ───────────────────────────────────────── -->
    <top>
        <Label fx:id="projectNameLabel"
               styleClass="project-detail-title"
               text="Nincs kiválasztott projekt"
               BorderPane.alignment="CENTER_LEFT">
            <BorderPane.margin><Insets top="10" right="12" bottom="6" left="12"/></BorderPane.margin>
        </Label>
    </top>

    <!-- ── Tartalom ────────────────────────────────────────────────────── -->
    <center>
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

            <!-- Fájlválasztók -->
            <TitledPane text="Bemeneti fájlok" collapsible="false" animated="false">
                <GridPane hgap="10" vgap="8">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    <columnConstraints>
                        <ColumnConstraints minWidth="150" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints prefWidth="100"/>
                    </columnConstraints>

                    <!-- Régi határozat -->
                    <Label text="Régi határozat:"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="oldDecisionLabel"   GridPane.rowIndex="0" GridPane.columnIndex="1"
                           styleClass="file-label" text="Nincs fájl kiválasztva" maxWidth="Infinity"/>
                    <Button text="Tallózás…"          GridPane.rowIndex="0" GridPane.columnIndex="2"
                            onAction="#onBrowseOldDecision" maxWidth="Infinity"/>

                    <!-- Új határozat -->
                    <Label text="Új határozat:"       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="newDecisionLabel"   GridPane.rowIndex="1" GridPane.columnIndex="1"
                           styleClass="file-label" text="Nincs fájl kiválasztva" maxWidth="Infinity"/>
                    <Button text="Tallózás…"          GridPane.rowIndex="1" GridPane.columnIndex="2"
                            onAction="#onBrowseNewDecision" maxWidth="Infinity"/>

                    <!-- Jelenlegi címke -->
                    <Label text="Jelenlegi címke:"    GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="labelFileLabel"     GridPane.rowIndex="2" GridPane.columnIndex="1"
                           styleClass="file-label" text="Nincs fájl kiválasztva" maxWidth="Infinity"/>
                    <Button text="Tallózás…"          GridPane.rowIndex="2" GridPane.columnIndex="2"
                            onAction="#onBrowseLabel" maxWidth="Infinity"/>
                </GridPane>
            </TitledPane>

            <!-- Futtatás sáv -->
            <VBox spacing="6">
                <Button fx:id="runButton"
                        text="▶  Elemzés futtatása"
                        styleClass="run-button"
                        maxWidth="Infinity"
                        onAction="#onRunAnalysis"/>
                <ProgressBar fx:id="progressBar"
                             maxWidth="Infinity"
                             progress="0"
                             visible="false"/>
                <Label fx:id="statusLabel"
                       styleClass="status-label"
                       text="Kész az elemzés elindítására."/>
            </VBox>

            <!-- Eredmény fülek (include) -->
            <fx:include fx:id="resultTabs" source="ResultTabsView.fxml" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

</BorderPane>
