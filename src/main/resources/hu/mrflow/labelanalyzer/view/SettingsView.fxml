<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    Ezt a DialogPane-t a SettingsController tölti be és egy Dialog-ba helyezi.
-->
<DialogPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hu.mrflow.labelanalyzer.view.SettingsController"
            prefWidth="580" prefHeight="540">

    <header>
        <Label text="Beállítások" styleClass="settings-header"/>
    </header>

    <content>
        <ScrollPane fitToWidth="true">
            <VBox spacing="14">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- Aktív provider -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Aktív AI szolgáltató:" minWidth="180"/>
                    <ComboBox fx:id="providerCombo" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Separator/>

                <!-- OpenAI -->
                <TitledPane text="OpenAI (ChatGPT)" collapsible="true" expanded="true">
                    <GridPane hgap="10" vgap="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <columnConstraints>
                            <ColumnConstraints minWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="API kulcs:"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="openAiKeyField"      GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="sk-…"/>
                        <Label text="Végpont URL:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="openAiEndpointField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Modell:"      GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="openAiModelField"    GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </TitledPane>

                <!-- Anthropic -->
                <TitledPane text="Anthropic (Claude)" collapsible="true" expanded="false">
                    <GridPane hgap="10" vgap="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <columnConstraints>
                            <ColumnConstraints minWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="API kulcs:"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="anthropicKeyField"      GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="sk-ant-…"/>
                        <Label text="Végpont URL:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="anthropicEndpointField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Modell:"      GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="anthropicModelField"    GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </TitledPane>

                <!-- Gemini -->
                <TitledPane text="Google (Gemini)" collapsible="true" expanded="false">
                    <GridPane hgap="10" vgap="8">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <columnConstraints>
                            <ColumnConstraints minWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="API kulcs:"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="geminiKeyField"      GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="AIza…"/>
                        <Label text="Végpont URL:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="geminiEndpointField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Modell:"      GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="geminiModelField"    GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
