<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Konzol appender – színes, olvasható formátum -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fájl appender – ~/.labelanalyzer/logs/app.log -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.labelanalyzer/logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Naponta új fájl, 30 napig tartja meg -->
            <fileNamePattern>${user.home}/.labelanalyzer/logs/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Apache POI és PDFBox zajt csökkentjük -->
    <logger name="org.apache.poi"    level="WARN"/>
    <logger name="org.apache.pdfbox" level="WARN"/>

    <!-- Saját kód DEBUG szinten -->
    <logger name="hu.mrflow.labelanalyzer" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>